common_col_names <- Reduce(intersect, list(
names(shed2020),
names(shed2021),
names(shed2022),
names(shed2023),
names(shed2024),
names(shed2025)))
#Merging all by the common columns
data <- rbind(shed2020 %.% select(common_col_names),
shed2021 %.% select(common_col_names),
shed2022 %.% select(common_col_names),
shed2023 %.% select(common_col_names),
shed2024 %.% select(common_col_names),
shed2025 %.% select(common_col_names))
